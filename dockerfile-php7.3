FROM php:7.3-fpm

# 更换为阿里云的 Debian 源并安装必要的包
RUN sed -i 's|http://deb.debian.org|http://mirrors.aliyun.com|g' /etc/apt/sources.list \
    && sed -i 's|http://security.debian.org|http://mirrors.aliyun.com|g' /etc/apt/sources.list \
    && apt-get update \
    && apt-get install -y \
        libzip-dev \
        libssl-dev \
        libcurl4-openssl-dev \
        pkg-config \
        git \
        unzip \
        procps \
        sudo \
        python3 \
        python3-pip \
        build-essential \
        cmake \
        wget \
        zlib1g-dev \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# 安装 Redis PHP 扩展（使用 http 协议）
RUN git clone -b 5.3.7 http://github.com/phpredis/phpredis.git /usr/src/php/ext/redis && \
    cd /usr/src/php/ext/redis && \
    phpize && \
    ./configure && \
    make && \
    make install && \
    docker-php-ext-enable redis

# 安装其他 PHP 扩展
RUN docker-php-ext-install pdo_mysql sockets pcntl bcmath zip

# 安装 PyPDF2
RUN pip3 install PyPDF2

# 更新 PECL 频道并安装 Swoole
RUN pecl channel-update pecl.php.net \
    && pecl install swoole-4.8.11 \
    && docker-php-ext-enable swoole

# 手动安装 libxlsxwriter
RUN git clone https://gitee.com/ChrisZhcn/libxlsxwriter.git /usr/src/libxlsxwriter && \
    cd /usr/src/libxlsxwriter && \
    cmake . && \
    make && \
    make install && \
    ldconfig

# 安装 xlswriter PHP 扩展
RUN pecl install xlswriter \
    && docker-php-ext-enable xlswriter

# 安装 Composer
RUN curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer \
    && chmod +x /usr/local/bin/composer

# 设置工作目录
WORKDIR /var/www/html
