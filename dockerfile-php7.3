FROM docker.m.daocloud.io/library/php:7.3-fpm

RUN sed -i 's@deb.debian.org@mirrors.aliyun.com@g; s@security.debian.org@mirrors.aliyun.com@g' /etc/apt/sources.list \
    && apt-get update \
    && apt-get install -y \
        libzip-dev \
        libssl-dev \
        libcurl4-openssl-dev \
        pkg-config \
        git \
        unzip \
        procps \
        sudo \
        python3 \
        python3-pip \
        build-essential \
        cmake \
        wget \
        zlib1g-dev \
        libfreetype6-dev \
        libjpeg62-turbo-dev \
        libpng-dev \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

COPY php-extension/packages/redis-5.3.7.tgz /tmp/php-extension-packages/redis-5.3.7.tgz
COPY php-extension/packages/swoole-4.8.11.tgz /tmp/php-extension-packages/swoole-4.8.11.tgz
COPY php-extension/packages/xdebug-3.1.6.tgz /tmp/php-extension-packages/xdebug-3.1.6.tgz
COPY php-extension/meminfo /usr/src/php-meminfo
COPY php-extension/xlswriter /usr/src/php-ext-xlswriter

# 安装 Redis PHP 扩展
RUN pecl install /tmp/php-extension-packages/redis-5.3.7.tgz \
    && docker-php-ext-enable redis

# 安装 GD 扩展（兼容 PHP 7.3）
RUN docker-php-ext-configure gd \
    --with-freetype-dir=/usr/include/ \
    --with-jpeg-dir=/usr/include/ \
    && docker-php-ext-install gd

# 安装其他 PHP 扩展
RUN docker-php-ext-install pdo_mysql sockets pcntl bcmath zip

# 安装 PyPDF2
RUN pip3 install -i https://mirrors.aliyun.com/pypi/simple/ --trusted-host mirrors.aliyun.com PyPDF2

# 安装 Swoole 扩展
RUN pecl install /tmp/php-extension-packages/swoole-4.8.11.tgz \
    && docker-php-ext-enable swoole

# 安装 meminfo 扩展
RUN cd /usr/src/php-meminfo/extension/php7 \
    && phpize \
    && ./configure --with-php-config=/usr/local/bin/php-config \
    && make \
    && make install \
    && docker-php-ext-enable meminfo \
    && rm -rf /usr/src/php-meminfo

# 安装 xdebug 并配置
RUN pecl install /tmp/php-extension-packages/xdebug-3.1.6.tgz

RUN echo "zend_extension=xdebug" >> /usr/local/etc/php/conf.d/docker-php-ext-xdebug.ini \
    && echo "xdebug.mode=debug" >> /usr/local/etc/php/conf.d/docker-php-ext-xdebug.ini \
    && echo "xdebug.start_with_request=yes" >> /usr/local/etc/php/conf.d/docker-php-ext-xdebug.ini \
    && echo "xdebug.client_host=host.docker.internal" >> /usr/local/etc/php/conf.d/docker-php-ext-xdebug.ini \
    && echo "xdebug.client_port=9001" >> /usr/local/etc/php/conf.d/docker-php-ext-xdebug.ini \
    && echo "xdebug.idekey=PHPSTORM" >> /usr/local/etc/php/conf.d/docker-php-ext-xdebug.ini \
    && echo "xdebug.max_nesting_level=512" >> /usr/local/etc/php/conf.d/docker-php-ext-xdebug.ini

# 安装 xlswriter PHP 扩展
RUN cd /usr/src/php-ext-xlswriter \
    && phpize \
    && ./configure --with-php-config=/usr/local/bin/php-config \
    && make \
    && make install \
    && docker-php-ext-enable xlswriter \
    && rm -rf /usr/src/php-ext-xlswriter /tmp/php-extension-packages

# 安装 Composer，并切换为阿里云镜像
COPY --from=docker.m.daocloud.io/library/composer:2 /usr/bin/composer /usr/local/bin/composer

RUN composer config -g repo.packagist composer https://mirrors.aliyun.com/composer/ \
    && chmod +x /usr/local/bin/composer

# 设置工作目录
WORKDIR /var/www/html
